#include "dtwdemo.h"
#include "windows.h"

/////////////////////////////////////////////////////////////////////////////
//
// Icon
//

// Icon with lowest ID value placed first to ensure application icon
// remains consistent on all systems.
IDI_DTWDEMO             ICON    DISCARDABLE     "DTWDEMO.ICO"
IDI_SMALL               ICON    DISCARDABLE     "DTWDEMO.ICO"

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDC_DTWDEMO  MENU DISCARDABLE
BEGIN
    POPUP "&Source Selection Test"
    BEGIN
        MENUITEM "S&elect Source...",           IDM_SELECT_SOURCE
        MENUITEM "Select Source By &Name...",   IDM_SELECT_SOURCE_BY_NAME
        MENUITEM "Select &Default Source...",   IDM_SELECT_DEFAULT_SOURCE
        MENUITEM "Select Source &Custom...",    IDM_SELECT_SOURCE_CUSTOM
        MENUITEM SEPARATOR
        MENUITEM "Source &Properties...",       IDM_SOURCE_PROPS
        MENUITEM SEPARATOR
        MENUITEM "&Close Source...",            IDM_CLOSE_SOURCE
        MENUITEM SEPARATOR
        MENUITEM "E&xit Demo",                  IDM_EXIT
    END
    POPUP "&Acquire Test"
    BEGIN
        MENUITEM "Acquire Native...",           IDM_ACQUIRE_NATIVE
        MENUITEM "Acquire Buffered...",         IDM_ACQUIRE_BUFFERED
        POPUP "Acquire File ..."
        BEGIN
            POPUP "BigTIFF"
            BEGIN
                MENUITEM "No compression",              IDM_ACQUIREFILE_BIGTIFF_NOCOMPRESSION
                MENUITEM "Group 3",                     IDM_ACQUIREFILE_BIGTIFF_GROUP3
                MENUITEM "Group 4",                     IDM_ACQUIREFILE_BIGTIFF_GROUP4
                MENUITEM "Flate",                       IDM_ACQUIREFILE_BIGTIFF_FLATE
                MENUITEM "JPEG",                        IDM_ACQUIREFILE_BIGTIFF_JPEG
                MENUITEM "LZW",                         IDM_ACQUIREFILE_BIGTIFF_LZW
                MENUITEM "Packbits",                    IDM_ACQUIREFILE_BIGTIFF_PACKBITS
            END
            MENUITEM "BMP",                         IDM_ACQUIREFILE_BMP
            MENUITEM "BMP-RLE",                     IDM_ACQUIREFILE_BMPRLE
            MENUITEM "DCX",                         IDM_ACQUIREFILE_DCX
            MENUITEM "Enhanced Meta File (EMF)",    IDM_ACQUIREFILE_ENHANCEDMETAFILE
            MENUITEM "GIF",                         IDM_ACQUIREFILE_GIF
            MENUITEM "ICO",                         IDM_ACQUIREFILE_ICO
            MENUITEM "ICO-Vista",                   IDM_ACQUIREFILE_ICOVISTA
            MENUITEM "JPEG",                        IDM_ACQUIREFILE_JPEG
            MENUITEM "JPEG-2000",                   IDM_ACQUIREFILE_JPEG2000
            MENUITEM "JPEG-XR",                     IDM_ACQUIREFILE_JPEGXR
            MENUITEM "Paintshop (PSD)",             IDM_ACQUIREFILE_PAINTSHOP
            MENUITEM "PCX",                         IDM_ACQUIREFILE_PCX
            MENUITEM "PDF",                         IDM_ACQUIREFILE_PDF
            MENUITEM "PNG",                         IDM_ACQUIREFILE_PNG
            MENUITEM "PostScript (Level 1)",        IDM_ACQUIREFILE_POSTSCRIPTLEVEL1
            MENUITEM "PostScript (Level 2)",        IDM_ACQUIREFILE_POSTSCRIPTLEVEL2
            MENUITEM "SVG",                         IDM_ACQUIREFILE_SVG
            MENUITEM "SVGZ",                        IDM_ACQUIREFILE_SVGZ
            MENUITEM "Targa (TGA)",                 IDM_ACQUIREFILE_TGA
            MENUITEM "Targa-RLE",                   IDM_ACQUIREFILE_TGARLE
            MENUITEM "Text (OCR)",                  IDM_ACQUIREFILE_TEXT
            POPUP "TIFF"
            BEGIN
                MENUITEM "No compression",              IDM_ACQUIREFILE_TIFF_NOCOMPRESSION
                MENUITEM "Group 3",                     IDM_ACQUIREFILE_TIFF_GROUP3
                MENUITEM "Group 4",                     IDM_ACQUIREFILE_TIFF_GROUP4
                MENUITEM "Flate",                       IDM_ACQUIREFILE_TIFF_FLATE
                MENUITEM "JPEG",                        IDM_ACQUIREFILE_TIFF_JPEG
                MENUITEM "LZW",                         IDM_ACQUIREFILE_TIFF_LZW
                MENUITEM "Packbits",                    IDM_ACQUIREFILE_TIFF_PACKBITS
            END
            MENUITEM "WEBP",                        IDM_ACQUIREFILE_WEBP
            MENUITEM "Windows Meta File (WMF)",     IDM_ACQUIREFILE_WINDOWSMETAFILE
            MENUITEM "Wireless Bitmap (WBMP)",      IDM_ACQUIREFILE_WIRELESSBITMAP
        END
        POPUP "Acquire File (Source Mode)..."
        BEGIN
            MENUITEM "Windows BMP",                 IDM_ACQUIREFILESOURCE_WINDOWSBMP
            MENUITEM "JPEG (JFIF)",                 IDM_ACQUIREFILESOURCE_JPEG
            MENUITEM "TIFF",                        IDM_ACQUIREFILESOURCE_TIFF
            MENUITEM "TIFF (Multipage)",            IDM_ACQUIREFILESOURCE_TIFFMULTIPAGE
            MENUITEM "PNG",                         IDM_ACQUIREFILESOURCE_PNG
            MENUITEM "PDF",                         IDM_ACQUIREFILESOURCE_PDF
            MENUITEM "PDF/A",                       IDM_ACQUIREFILESOURCE_PDFA
            MENUITEM "PDF/A2",                      IDM_ACQUIREFILESOURCE_PDFA2
            MENUITEM "PDFRASTER",                   IDM_ACQUIREFILESOURCE_PDFRASTER
            MENUITEM "FlashPix (FPX)",              IDM_ACQUIREFILESOURCE_FLASHPIX
            MENUITEM "EXIF",                        IDM_ACQUIREFILESOURCE_EXIF
            MENUITEM "SPIFF",                       IDM_ACQUIREFILESOURCE_SPIFF
            MENUITEM "XBM",                         IDM_ACQUIREFILESOURCE_XBM
            MENUITEM "Macintosh PICT",              IDM_ACQUIREFILESOURCE_PICT
            MENUITEM "JP2 (JPEG ISO/IEC 15444-1)",  IDM_ACQUIREFILESOURCE_JP2
            MENUITEM "JPX (JPEG ISO/IEC 15444-2)",  IDM_ACQUIREFILESOURCE_JPX
            MENUITEM "DEJAVU",                      IDM_ACQUIREFILESOURCE_DEJAVU
        END
        MENUITEM SEPARATOR
        MENUITEM "Show Preview",                IDM_SHOW_PREVIEW
        MENUITEM "Use Source UI",               IDM_USE_SOURCE_UI
        MENUITEM "Discard Blank Pages...",      IDM_DISCARD_BLANKS
        MENUITEM "Show Barcode Information",    IDM_SHOW_BARCODEINFO
        MENUITEM SEPARATOR
        MENUITEM "Use GetMessage TWAIN Loop",   IDM_ACQUIRETEST_USEGETMESSAGE
    END
    POPUP "&TWAIN Logging"
    BEGIN
        MENUITEM "Logging Options...",          IDM_LOGGING_OPTIONS
    END
    POPUP "Language"
    BEGIN
        MENUITEM "Dutch",                       ID_LANGUAGE_DUTCH
        MENUITEM "English",                     ID_LANGUAGE_ENGLISH
        MENUITEM "French",                      ID_LANGUAGE_FRENCH
        MENUITEM "German",                      ID_LANGUAGE_GERMAN
        MENUITEM "Greek",                       ID_LANGUAGE_GREEK
        MENUITEM "Italian",                     ID_LANGUAGE_ITALIAN
        MENUITEM "Japanese",                    ID_LANGUAGE_JAPANESE
        MENUITEM "Korean",                      ID_LANGUAGE_KOREAN
        MENUITEM "Portuguese",                  ID_LANGUAGE_PORTUGUESE
        MENUITEM "Romanian",                    ID_LANGUAGE_ROMANIAN
        MENUITEM "Russian",                     ID_LANGUAGE_RUSSIAN
        MENUITEM "Simplified Chinese",          ID_LANGUAGE_SIMPLIFIEDCHINESE
        MENUITEM "Traditioanl Chinese",         ID_LANGUAGE_TRADITIONALCHINESE
        MENUITEM "Spanish",                     ID_LANGUAGE_SPANISH
        MENUITEM "Custom Language...",          ID_LANGUAGE_CUSTOMLANGUAGE
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About ...",                  IDM_ABOUT
    END
END


/////////////////////////////////////////////////////////////////////////////
//
// Accelerator
//

IDC_EXAMPLE1 ACCELERATORS MOVEABLE PURE
BEGIN
    "?",            IDM_ABOUT,              ASCII,  ALT
    "/",            IDM_ABOUT,              ASCII,  ALT
END


