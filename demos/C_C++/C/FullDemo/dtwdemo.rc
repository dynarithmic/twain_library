IDD_ABOUTBOX DIALOG DISCARDABLE  22, 17, 320, 125
STYLE DS_MODALFRAME | WS_CAPTION | WS_SYSMENU
CAPTION "About"
FONT 8, "MS Sans Serif"
BEGIN
    ICON            IDI_DTWDEMO,IDC_MYICON,14,9,16,16
    LTEXT           "DTWDEMO Example",IDC_STATIC,39,10,119,8, SS_NOPREFIX
    EDITTEXT        IDC_edCopyright, 39, 20, 280, 100, ES_MULTILINE | ES_AUTOVSCROLL | ES_AUTOHSCROLL | ES_READONLY | NOT WS_BORDER | NOT WS_TABSTOP 
                                                      | WS_VSCROLL | WS_HSCROLL
    DEFPUSHBUTTON   "OK",IDOK,250,6,30,11,WS_GROUP
END

